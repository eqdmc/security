#!/usr/bin/env bash
# rax-secrets — Provision secrets through the rax/secrets HITL flow.
#
# Every secret goes through: collect metadata → encrypt with sops → store →
# update token manifest → verify → clean up.
#
# Usage:
#   rax-secrets provision github-app merge-bot \
#     --provider github \
#     --purpose "PR review and merge approval" \
#     --permissions "pull_requests:write,contents:write" \
#     --usage "gh-merge-bot-auth CLI tool" \
#     --source ~/Downloads/key.pem
#
#   rax-secrets provision api-key deepseek \
#     --provider deepseek \
#     --purpose "AI provider for agent runtime" \
#     --usage "opencode provider config" \
#     --source ~/Downloads/deepseek-key.txt
#
#   rax-secrets list                    # show all provisioned secrets
#   rax-secrets info <token-id>         # show details for one secret
#
# Types: github-app, pat, api-key, ssh-key, generic
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$SCRIPT_DIR/lib/rax-secrets.sh"

case "${1:-}" in
  provision)
    shift
    rax_secrets_provision "$@"
    ;;
  list)
    python3 -c "
import json
with open('$RAX_TOKEN_MANIFEST') as f:
    m = json.load(f)
for t in m.get('tokens', []):
    print(f\"  {t.get('id', '?'):35s} {t.get('type', '?'):15s} {t.get('status', '?'):10s} {t.get('category', '?'):15s}\")
" 2>/dev/null || echo "  (no token manifest)"
    ;;
  info)
    python3 -c "
import json, sys
token_id = sys.argv[1] if len(sys.argv) > 1 else ''
with open('$RAX_TOKEN_MANIFEST') as f:
    m = json.load(f)
for t in m.get('tokens', []):
    if t.get('id') == token_id:
        print(json.dumps(t, indent=2))
        sys.exit(0)
print(f'Token \"{token_id}\" not found')
" "${2:-}" 2>/dev/null || echo "  (error)"
    ;;
  *)
    echo "Usage: rax-secrets {provision|list|info}"
    echo ""
    echo "  provision <type> <name> --provider STR --purpose STR [--permissions STR] [--usage STR] [--source PATH]"
    echo "  list"
    echo "  info <token-id>"
    ;;
esac