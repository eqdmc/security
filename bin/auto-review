#!/usr/bin/env python3
"""auto-review — Automated PR review with binary checklist and agent findings.

Posts a structured review comment on any PR with:
  ✅/❌ Binary checklist (CI, conflicts, license, security)
  🔍 Automated review findings (correctness, security, tests)
  📊 Overall assessment

Usage:
  auto-review <pr-number> [--repo <repo>]
  auto-review --all          # review all open PRs
  auto-review <pr-number> --publish  # post results as PR comment
"""

import json
import os
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path

REPO_DIR = Path(__file__).parent.parent
DEFAULT_REPO = "eqdmc/security"


def gh_api(path, repo=DEFAULT_REPO):
    try:
        r = subprocess.run(
            ["gh", "api", f"repos/{repo}/{path}"],
            capture_output=True, text=True, timeout=15
        )
        if r.returncode == 0:
            return json.loads(r.stdout)
        return None
    except:
        return None


def get_pr_info(pr_num, repo):
    """Get PR details."""
    result = subprocess.run(
        ["gh", "pr", "view", str(pr_num), "-R", repo,
         "--json", "title,body,author,files,additions,deletions,headRefName,baseRefName,state,mergeable,statusCheckRollup,reviews",
         "--jq", "."],
        capture_output=True, text=True, timeout=15
    )
    if result.returncode != 0:
        print(f"Error fetching PR: {result.stderr}")
        sys.exit(1)
    return json.loads(result.stdout)


def get_diff(pr_num, repo):
    """Get PR diff."""
    result = subprocess.run(
        ["gh", "pr", "diff", str(pr_num), "-R", repo],
        capture_output=True, text=True, timeout=30
    )
    if result.returncode == 0:
        return result.stdout[:5000]
    return "(diff not available)"


def build_checklist(pr):
    """Build binary checklist from PR data."""
    checks = {}
    
    # CI status
    ci_results = pr.get("statusCheckRollup", [])
    failures = [c for c in ci_results if c.get("conclusion") == "FAILURE"]
    successes = [c for c in ci_results if c.get("conclusion") == "SUCCESS"]
    pending = [c for c in ci_results if not c.get("conclusion")]
    
    checks["ci"] = {
        "status": "pass" if not failures else "fail",
        "detail": f"{len(successes)} pass, {len(failures)} fail, {len(pending)} pending"
    }
    
    # Merge conflicts
    mergeable = pr.get("mergeable", "UNKNOWN")
    checks["conflicts"] = {
        "status": "pass" if mergeable == "MERGEABLE" else "fail",
        "detail": mergeable
    }
    
    # License check (from files changed)
    changed_files = [f.get("path", "") for f in pr.get("files", [])]
    license_files = [f for f in changed_files if "LICENSE" in f or "license" in f or "COPYING" in f]
    checks["license"] = {
        "status": "info",
        "detail": f"{len(license_files)} license file(s) changed" if license_files else "no license files changed"
    }
    
    # Security-sensitive files
    security_files = [f for f in changed_files if any(k in f.lower() for k in 
        ["secret", "token", "credential", ".pem", ".key", "password", "guard", "hook"])]
    checks["security"] = {
        "status": "review" if security_files else "pass",
        "detail": f"{len(security_files)} security-relevant file(s)" if security_files else "no security files changed"
    }
    
    # Size assessment
    additions = pr.get("additions", 0)
    if additions > 1000:
        checks["size"] = {"status": "warn", "detail": f"+{additions} lines — large PR, consider splitting"}
    else:
        checks["size"] = {"status": "pass", "detail": f"+{additions} lines"}
    
    return checks


def build_review_comment(pr_num, repo, pr, checklist):
    """Build the review comment markdown."""
    title = pr.get("title", "unknown")
    author = pr.get("author", {}).get("login", "unknown")
    additions = pr.get("additions", 0)
    deletions = pr.get("deletions", 0)
    
    lines = [
        f"## 🤖 Auto-Review: #{pr_num}",
        "",
        f"**{title}** by @{author}  (+{additions}/-{deletions})",
        "",
        "### Binary Checklist",
        "",
    ]
    
    icons = {"pass": "✅", "fail": "❌", "warn": "⚠️", "review": "🔍", "info": "ℹ️"}
    for key, check in sorted(checklist.items()):
        icon = icons.get(check["status"], "❓")
        lines.append(f"| {icon} {key.capitalize():12s} | {check['detail']:50s} |")
    
    lines.append("")
    lines.append("### Automated Review Findings")
    lines.append("")
    lines.append("*Correctness:* Pending agent review")
    lines.append("*Security:* " + ("⚠️ flags detected" if checklist.get("security", {}).get("status") == "review" else "✅ clean"))
    lines.append("*Tests:* Pending agent review")
    lines.append("")
    lines.append("---")
    lines.append(f"*Auto-generated by eqdmc/security bin/auto-review*")
    
    return "\n".join(lines)


def post_comment(pr_num, repo, body):
    """Post a comment on the PR."""
    with tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False) as f:
        f.write(body)
        comment_file = f.name
    
    result = subprocess.run(
        ["gh", "pr", "comment", str(pr_num), "-R", repo, "--body-file", comment_file],
        capture_output=True, text=True, timeout=15
    )
    os.unlink(comment_file)
    return result.returncode == 0


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    if "--all" in sys.argv:
        repos = [DEFAULT_REPO]
        for i, a in enumerate(sys.argv):
            if a == "--repos" and i + 1 < len(sys.argv):
                repos = sys.argv[i + 1].split(",")
        
        for repo in repos:
            result = subprocess.run(
                ["gh", "pr", "list", "-R", repo, "--state", "open",
                 "--json", "number", "--jq", ".[].number"],
                capture_output=True, text=True, timeout=15
            )
            if result.returncode == 0:
                for pr_num in result.stdout.strip().split("\n"):
                    if pr_num:
                        print(f"\n── Reviewing {repo}#{pr_num} ──")
                        review_pr(int(pr_num), repo, "--publish" in sys.argv)
        return

    if sys.argv[1].isdigit():
        pr_num = int(sys.argv[1])
        repo = DEFAULT_REPO
        for i, a in enumerate(sys.argv):
            if a == "--repo" and i + 1 < len(sys.argv):
                repo = sys.argv[i + 1]
        publish = "--publish" in sys.argv
        review_pr(pr_num, repo, publish)


def review_pr(pr_num, repo, publish=False):
    pr = get_pr_info(pr_num, repo)
    checklist = build_checklist(pr)
    comment = build_review_comment(pr_num, repo, pr, checklist)
    
    print(comment)
    print()
    
    # Summary line
    fails = [k for k, v in checklist.items() if v["status"] == "fail"]
    if fails:
        print(f"❌ {len(fails)} check(s) failed: {', '.join(fails)}")
    else:
        print("✅ All checks pass")
    
    if publish:
        if post_comment(pr_num, repo, comment):
            print(f"\n✅ Review comment posted to {repo}#{pr_num}")
        else:
            print(f"\n❌ Failed to post comment")
    
    # Return exit code based on failures
    if fails:
        sys.exit(1)


if __name__ == "__main__":
    main()
