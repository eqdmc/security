#!/bin/bash
# rax — Run staged Action eXecution
#
# Portable HITL approval tool for dangerous agent-initiated actions.
# Works with any harness (Claude Code, OpenCode, Cursor, etc.),
# any environment (local, Docker, VPS).
#
# Configuration is 100% via env vars — the harness sets them at session start:
#   RAX_PENDING_FILE  — where to read the staged action
#   RAX_STATE_DIR     — directory for result + log files
#   RAX_RESULT_FILE   — structured result (harness adapter reads this)
#   RAX_AUDIT_FILE    — append-only audit log
#   RAX_SESSION_ID    — session correlation
#   RAX_POLICY_FILE   — danger patterns + thresholds (YAML)
set -euo pipefail

_rax_path="$(realpath "$(command -v rax 2>/dev/null || echo "$0")" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")"
_rax_bin="$(cd "$(dirname "$_rax_path")" && pwd)"
_rax_repo="$(cd "$_rax_bin/.." && pwd)"
source "$_rax_repo/lib/rax-config.sh"
RAX_VERSION="${RAX_CLI_VERSION:-0.2.1}"

# --- Args ---
if [ "${1:-}" = "--version" ]; then
    echo "rax $RAX_VERSION"
    exit 0
fi

if [ "${1:-}" = "--show-policy" ]; then
    POLICY_FILE="${RAX_POLICY_FILE:-$HOME/.rax/policy.yml}"
    echo "Policy: $POLICY_FILE"
    if [ -f "$POLICY_FILE" ]; then
        cat "$POLICY_FILE"
    else
        echo "(no policy file — using hardcoded defaults)"
    fi
    exit 0
fi

# --- Multi-action support ---
# Usage: rax [N] or rax list
#   rax     — run the lowest-numbered pending action
#   rax 2   — run pending action ~/.rax/pending/2.sh
#   rax list — list all pending actions
RAX_PENDING_DIR="${RAX_PENDING_DIR:-$HOME/.rax/pending}"
RAX_CMD="${1:-}"

if [ "$RAX_CMD" = "list" ]; then
    echo "Staged actions:"
    if [ -d "$RAX_PENDING_DIR" ]; then
        for f in "$RAX_PENDING_DIR"/[0-9]*.sh; do
            [ -f "$f" ] || continue
            num=$(basename "$f" .sh)
            purpose=$(grep -m1 '^# Purpose:' "$f" 2>/dev/null | sed 's/.*: *//' || echo "no purpose")
            echo "  rax $num — $purpose"
        done
    fi
    exit 0
fi

# --- Paths (all env-var driven, sensible defaults) ---
RAX_STATE_DIR="${RAX_STATE_DIR:-$HOME/.rax/state}"

# Diagnostic: if there are files in the pending dir but we can't find them, warn
if [ -d "$RAX_PENDING_DIR" ] && [ -z "${1:-}" ]; then
    _file_count=$(ls "$RAX_PENDING_DIR"/[0-9]*.sh 2>/dev/null | wc -l)
    if [ "$_file_count" -gt 0 ] && [ ! -f "$HOME/.rax/pending.sh" ]; then
        : # Files exist and no old single-file — should be fine
    fi
    unset _file_count
fi

# Resolve pending action: RAX_PENDING_FILE > numbered arg > numbered dir > single file
if [ -n "${RAX_PENDING_FILE:-}" ]; then
    ACTION="$RAX_PENDING_FILE"
elif [ -n "$RAX_CMD" ] && [ "$RAX_CMD" -eq "$RAX_CMD" ] 2>/dev/null; then
    ACTION="$RAX_PENDING_DIR/$RAX_CMD.sh"
    mkdir -p "$RAX_PENDING_DIR"
elif [ -d "$RAX_PENDING_DIR" ] && ls "$RAX_PENDING_DIR"/[0-9]*.sh >/dev/null 2>&1; then
    pending_files=($(ls "$RAX_PENDING_DIR"/[0-9]*.sh 2>/dev/null | sort))
    if [ ${#pending_files[@]} -eq 1 ]; then
        ACTION="${pending_files[0]}"
    else
        echo ""
        echo "  Multiple actions staged:"
        echo "  $(printf '%0.s─' {1..60})"
        printf "  %-6s %-10s %s\n" "Num" "Age" "Purpose"
        echo "  $(printf '%0.s─' {1..60})"
        for f in "${pending_files[@]}"; do
            num=$(basename "$f" .sh)
            purpose=$(grep -m1 '^# Purpose:' "$f" 2>/dev/null | sed 's/.*: *//' || echo "no purpose")
            age_s=$(( $(date +%s) - $(stat -c '%Y' "$f" 2>/dev/null || echo 0) ))
            if [ "$age_s" -lt 60 ]; then
                age_str="${age_s}s"
            elif [ "$age_s" -lt 3600 ]; then
                age_str="$((age_s / 60))m"
            else
                age_str="$((age_s / 3600))h"
            fi
            printf "  %-6s %-10s %s\n" "$num" "$age_str" "$purpose"
        done
        echo "  $(printf '%0.s─' {1..60})"
        echo "  Run: rax <number>"
        echo ""
        exit 0
    fi
elif [ -f "$HOME/.rax/pending.sh" ]; then
    ACTION="$HOME/.rax/pending.sh"
else
    echo "No pending actions. Stage one with: rax list"
    exit 0
fi

RESULT_FILE="${RAX_RESULT_FILE:-$RAX_STATE_DIR/last-result.json}"
AUDIT_FILE="${RAX_AUDIT_FILE:-$RAX_STATE_DIR/audit.jsonl}"
SESSION_ID="${RAX_SESSION_ID:-unknown}"
POLICY_FILE="${RAX_POLICY_FILE:-$HOME/.rax/policy.yml}"

mkdir -p "$RAX_STATE_DIR"

if [ ! -f "$ACTION" ]; then
    echo "No pending action."
    exit 0
fi

# --- ANSI colors ---
RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
WHITE='\033[0;37m'
DIM='\033[38;5;242m'
BOLD='\033[1m'
RESET='\033[0m'
CHECK='\xE2\x9C\x94'
CROSS='\xE2\x9C\x98'
WARN_ICON='\xE2\x9A\xA0'

# --- Extract metadata ---
extract_header() {
    local key="$1" file="$2"
    awk -v k="$key" '
        match($0, "^[[:space:]]*#[[:space:]]*" k "[[:space:]]*:[[:space:]]*") {
            val = substr($0, RSTART + RLENGTH)
            sub(/[[:space:]]+$/, "", val)
            print val
            exit
        }
    ' "$file" 2>/dev/null
}

PURPOSE=$(extract_header "Purpose" "$ACTION")
DESCRIPTION=$(extract_header "Description" "$ACTION")
VERIFY_CMD=$(extract_header "Verify" "$ACTION")
ROLLBACK_CMD=$(extract_header "Rollback" "$ACTION")
ISSUE=$(extract_header "Issue" "$ACTION" | sed 's/^#*//' | awk '{print $1}')
ACTION_ID=$(extract_header "Action-ID" "$ACTION")
if [ -z "$ACTION_ID" ]; then
    ACTION_ID="rsax-$(date +%Y-%m-%d)-adhoc-$(date +%s | tail -c 5)"
fi
REPO_HEADER=$(extract_header "Repo" "$ACTION")
WORKDIR_HEADER=$(extract_header "Workdir" "$ACTION")
INTERACTIVE_HEADER=$(extract_header "Interactive" "$ACTION")

# --- Pending file permission check ---
_perms=""
if stat -f '%Lp' "$ACTION" >/dev/null 2>&1; then
    _perms=$(stat -f '%Lp' "$ACTION")
else
    _perms=$(stat -c '%a' "$ACTION" 2>/dev/null || echo "")
fi
if [ -n "$_perms" ] && [ "$_perms" != "600" ] && [ "$_perms" != "700" ]; then
    printf "${YELLOW}${WARN_ICON}  Pending file permissions: %s (expected 600)${RESET}\n" "$_perms"
fi

# --- Repo detection (from invoker's cwd, BEFORE any cd) ---
ORIGINAL_DIR="$(pwd)"
DETECTED_REPO=""
if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    _remote_url=$(git remote get-url origin 2>/dev/null || echo "")
    if [ -n "$_remote_url" ]; then
        # Handle ssh://, git@, https:// (with optional credentials)
        DETECTED_REPO=$(echo "$_remote_url" | sed -E 's#^(ssh://[^/]+/|git@[^:]+:|https?://([^@/]+@)?[^/]+/)##; s#\.git$##')
    fi
fi

# --- Workdir routing (always use Workdir if available — run from anywhere) ---
if [ -n "$WORKDIR_HEADER" ]; then
    WORKDIR_RESOLVED=$(realpath "$WORKDIR_HEADER" 2>/dev/null || echo "")
    if [ -z "$WORKDIR_RESOLVED" ] || [ ! -d "$WORKDIR_RESOLVED" ]; then
        echo ""
        printf "${RED}${BOLD}BLOCKED:${RESET} Workdir does not exist: %s\n" "$WORKDIR_HEADER"
        printf "  ${DIM}Expected at: %s${RESET}\n" "$WORKDIR_HEADER"
        exit 1
    fi
    cd "$WORKDIR_RESOLVED"
fi

# --- Repo validation (AFTER cd — checks the action's target repo) ---
if [ -n "$REPO_HEADER" ]; then
    _rax_repo_after=""
    if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        _rax_url=$(git remote get-url origin 2>/dev/null || echo "")
        if [ -n "$_rax_url" ]; then
            _rax_repo_after=$(echo "$_rax_url" | sed -E 's#^(ssh://[^/]+/|git@[^:]+:|https?://([^@/]+@)?[^/]+/)##; s#\.git$##')
        fi
    fi
    if [ -n "$_rax_repo_after" ] && [ "$REPO_HEADER" != "$_rax_repo_after" ]; then
        echo ""
        printf "${YELLOW}${WARN_ICON}  Repository mismatch — action targets %s, current dir is %s${RESET}\n" \
            "$REPO_HEADER" "$_rax_repo_after"
        printf "  ${DIM}Running anyway (Workdir resolves to the action's target repo).${RESET}\n"
    fi
    unset _rax_repo_after _rax_url
fi

# --- Validation warnings ---
VALIDATION_WARNINGS=""
if [ -z "$PURPOSE" ]; then
    VALIDATION_WARNINGS="${VALIDATION_WARNINGS}$(printf "  ${RED}${CROSS} Missing # Purpose: header — action has no description${RESET}")\n"
fi
if [ -z "$VERIFY_CMD" ]; then
    VALIDATION_WARNINGS="${VALIDATION_WARNINGS}$(printf "  ${YELLOW}${WARN_ICON} No # Verify: header — action cannot be automatically confirmed${RESET}")\n"
fi
if [ -z "$ROLLBACK_CMD" ]; then
    VALIDATION_WARNINGS="${VALIDATION_WARNINGS}$(printf "  ${YELLOW}${WARN_ICON} No # Rollback: header — action may not be reversible${RESET}")\n"
fi
if [ -z "$REPO_HEADER" ] && [ -z "$WORKDIR_HEADER" ]; then
    VALIDATION_WARNINGS="${VALIDATION_WARNINGS}$(printf "  ${YELLOW}${WARN_ICON} No # Repo: or # Workdir: header — action runs from cwd with no repo binding${RESET}")\n"
fi

# --- Protected path check ---
# Load protected patterns from policy file if it exists, else use defaults.
# Protected paths are things rax refuses to touch (harness config, etc.).
CODE_ONLY=$(grep -v '^\s*#' "$ACTION" || true)
PROTECTED_BLOCKED=false

if [ -f "$POLICY_FILE" ]; then
    while IFS= read -r pattern; do
        [ -z "$pattern" ] && continue
        if echo "$CODE_ONLY" | grep -qE "$pattern"; then
            PROTECTED_BLOCKED=true
            break
        fi
    done < <(python3 -c "
import sys, json
try:
    import yaml
    policy = yaml.safe_load(open('$POLICY_FILE'))
except ImportError:
    # No PyYAML — parse protected_patterns manually
    policy = {}
    with open('$POLICY_FILE') as f:
        in_protected = False
        for line in f:
            stripped = line.strip()
            if stripped == 'protected_patterns:':
                in_protected = True
                continue
            if in_protected:
                if stripped.startswith('- '):
                    val = stripped[2:].strip().strip(\"'\").strip('\"')
                    print(val)
                elif stripped and not stripped.startswith('#'):
                    break
" 2>/dev/null)
fi

if ! $PROTECTED_BLOCKED; then
    if echo "$CODE_ONLY" | grep -qE '>\s*~/\.(claude|opencode)/(settings\.json|rules/|skills/|agents/|commands/)' || \
       echo "$CODE_ONLY" | grep -qE 'config-unlock'; then
        PROTECTED_BLOCKED=true
    fi
fi

if $PROTECTED_BLOCKED; then
    echo ""
    printf "${RED}${BOLD}BLOCKED:${RESET} This action edits protected config files.\n"
    printf "Use your harness's config-unlock mechanism instead of rax.\n"
    printf "${DIM}rax is for privileged commands (brew, chmod, secrets, git destructive).\n"
    printf "config-unlock grants the agent permission to edit config directly.${RESET}\n"
    exit 1
fi

# ━━━ HEADER ━━━
echo ""
printf "${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
printf "${BOLD}${MAGENTA}  RUN — STAGED ACTION${RESET}\n"
printf "${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"

wrap_at_col16() {
    echo "$1" | fold -s -w 60 | awk 'NR==1{print; next}{printf "                %s\n", $0}'
}

# ─── ACTION ───
echo ""
printf "${CYAN}───── ACTION ──────────────────────────────────────────────${RESET}\n"
echo ""
printf "  ${DIM}Action ID:    %s${RESET}\n" "$ACTION_ID"
echo ""
printf "  ${BOLD}Title:${RESET}        "
wrap_at_col16 "${PURPOSE:-<no purpose provided>}"

if [ -n "$DESCRIPTION" ]; then
    echo ""
    printf "  ${BOLD}Description:${RESET}  "
    wrap_at_col16 "$DESCRIPTION"
fi

if [ -n "$VERIFY_CMD" ]; then
    echo ""
    printf "  ${BOLD}Verify:${RESET}       Runs after action completes to confirm it worked.\n"
    printf "                ${CYAN}"
    wrap_at_col16 "$VERIFY_CMD"
    printf "${RESET}                ${DIM}Exit 0 = pass, non-zero = fail.${RESET}\n"
fi
if [ -n "$ROLLBACK_CMD" ]; then
    echo ""
    printf "  ${BOLD}Rollback:${RESET}     If something goes wrong, undo with:\n"
    printf "                ${YELLOW}"
    wrap_at_col16 "$ROLLBACK_CMD"
    printf "${RESET}"
fi
if [ -n "$ISSUE" ]; then
    echo ""
    printf "  ${BOLD}Issue:${RESET}        #${ISSUE} ${DIM}— result will auto-comment if gh + issue-verify available${RESET}\n"
fi

# ─── REPO CONTEXT ───
echo ""
printf "${CYAN}───── REPO CONTEXT ────────────────────────────────────────${RESET}\n"
echo ""
if [ -n "$WORKDIR_HEADER" ]; then
    printf "  ${GREEN}${CHECK} Workdir:${RESET}    %s\n" "$WORKDIR_HEADER"
else
    printf "  ${DIM}  Workdir:    (not set — running from %s)${RESET}\n" "$(pwd)"
fi
if [ -n "$REPO_HEADER" ]; then
    if [ -n "$DETECTED_REPO" ] && [ "$REPO_HEADER" = "$DETECTED_REPO" ]; then
        printf "  ${GREEN}${CHECK} Repo:${RESET}       %s\n" "$REPO_HEADER"
    else
        printf "  ${YELLOW}${WARN_ICON} Repo:${RESET}       %s ${YELLOW}(UNVERIFIED — no git remote to check against)${RESET}\n" "$REPO_HEADER"
    fi
elif [ -n "$DETECTED_REPO" ]; then
    printf "  ${DIM}  Repo:       (not set — cwd is %s)${RESET}\n" "$DETECTED_REPO"
else
    printf "  ${DIM}  Repo:       (not set — no git remote detected)${RESET}\n"
fi
if [ -n "$_perms" ]; then
    if [ "$_perms" = "600" ] || [ "$_perms" = "700" ]; then
        printf "  ${GREEN}${CHECK} Perms:${RESET}      %s\n" "$_perms"
    else
        printf "  ${YELLOW}${WARN_ICON} Perms:${RESET}      %s ${YELLOW}(expected 600)${RESET}\n" "$_perms"
    fi
fi

if [ -n "$VALIDATION_WARNINGS" ]; then
    echo ""
    printf "$VALIDATION_WARNINGS"
fi

# ─── CODE ───
echo ""
printf "${BLUE}───── CODE ────────────────────────────────────────────────${RESET}\n"
echo ""

tmp_code="$(mktemp -t rax-code.XXXXXX)"
awk '
BEGIN { in_header=1 }
/^#!/ { next }
/^# / && in_header { next }
/^set -euo/ { next }
/^$/ && in_header { next }
{ in_header=0; print }
' "$ACTION" > "$tmp_code"

if command -v bat >/dev/null 2>&1; then
    bat \
        --language=bash \
        --style=numbers \
        --color=always \
        --paging=never \
        --wrap=auto \
        "$tmp_code" 2>/dev/null | sed 's/^/  /'
else
    awk '
BEGIN { in_header=1; line=0; width=70 }
/^#!/ { next }
/^# / && in_header { next }
/^set -euo/ { next }
/^$/ && in_header { next }

function wrap_break(s, w,    i) {
    for (i = w; i > w * 3 / 4; i--) {
        if (substr(s, i, 1) == " ") return i
    }
    return 0
}

{
    in_header=0
    line++
    content = $0

    match(content, /^[[:space:]]*/)
    leading = substr(content, 1, RLENGTH)
    is_comment = (content ~ /^[[:space:]]*#/)

    if (length(content) <= width) {
        if (is_comment) {
            printf "  \033[38;5;242m%2d  %s\033[0m\n", line, content
        } else {
            printf "  \033[38;5;242m%2d\033[0m  %s\n", line, content
        }
        next
    }

    brk = wrap_break(content, width)
    if (brk > 0) {
        first = substr(content, 1, brk - 1)
        rest = substr(content, brk + 1)
    } else {
        first = substr(content, 1, width)
        rest = substr(content, width + 1)
    }
    if (is_comment) {
        printf "  \033[38;5;242m%2d  %s\033[0m\n", line, first
    } else {
        printf "  \033[38;5;242m%2d\033[0m  %s\n", line, first
    }

    cont_width = width - length(leading)
    if (cont_width < 20) cont_width = 20
    while (length(rest) > 0) {
        if (length(rest) <= cont_width) {
            printf "  \033[38;5;242m  \033[0m  %s%s\n", leading, rest
            rest = ""
        } else {
            sbrk = wrap_break(rest, cont_width)
            if (sbrk > 0) {
                seg = substr(rest, 1, sbrk - 1)
                rest = substr(rest, sbrk + 1)
            } else {
                seg = substr(rest, 1, cont_width)
                rest = substr(rest, cont_width + 1)
            }
            printf "  \033[38;5;242m  \033[0m  %s%s\n", leading, seg
        }
    }
}
' "$tmp_code"
fi
rm -f "$tmp_code"

# --- Risk audit ---
DANGER=0
FINDINGS=""

finding() {
    local points="$1" level="$2" msg="$3" detail="$4"
    DANGER=$((DANGER + points))
    case "$level" in
        critical) color="$RED" ;;
        high)     color="$YELLOW" ;;
        medium)   color="$CYAN" ;;
        low)      color="$BLUE" ;;
        *)        color="$RESET" ;;
    esac
    FINDINGS="${FINDINGS}$(printf "  ${color}${BOLD}+%-3d${RESET} ${color}[%s]${RESET}  %s" "$points" "$level" "$msg")\n"
    if [ -n "$detail" ]; then
        FINDINGS="${FINDINGS}$(printf "       ${DIM}%s${RESET}" "$detail")\n"
    fi
}

# Load findings from policy file if available — uses Python regex (not grep)
# so PCRE-style patterns like (?i) and \b work correctly.
_ran_policy_findings=false
if [ -f "$POLICY_FILE" ]; then
    while IFS='|' read -r points level message detail; do
        [ -z "$points" ] && continue
        finding "$points" "$level" "$message" "$detail"
    done < <(python3 -c "
import re, sys

code = sys.stdin.read()

# Parse policy YAML (try PyYAML, fall back to manual parse)
policy = None
try:
    import yaml
    policy = yaml.safe_load(open('$POLICY_FILE'))
except ImportError:
    # Manual parse for findings section
    findings = []
    with open('$POLICY_FILE') as f:
        in_findings = False
        current = {}
        for line in f:
            stripped = line.strip()
            if stripped == 'findings:':
                in_findings = True
                continue
            if not in_findings:
                continue
            if stripped.startswith('- pattern:'):
                if current:
                    findings.append(current)
                current = {'pattern': stripped.split(':', 1)[1].strip().strip(\"'\").strip('\"')}
            elif stripped.startswith('points:') and current:
                current['points'] = int(stripped.split(':', 1)[1].strip())
            elif stripped.startswith('level:') and current:
                current['level'] = stripped.split(':', 1)[1].strip()
            elif stripped.startswith('message:') and current:
                current['message'] = stripped.split(':', 1)[1].strip().strip('\"')
            elif stripped.startswith('detail:') and current:
                current['detail'] = stripped.split(':', 1)[1].strip().strip('\"')
        if current:
            findings.append(current)
    policy = {'findings': findings}

if policy and 'findings' in policy:
    for f in policy['findings']:
        pattern = f.get('pattern', '')
        if not pattern:
            continue
        if re.search(pattern, code):
            print('%s|%s|%s|%s' % (
                f.get('points', 0), f.get('level', 'medium'),
                f.get('message', ''), f.get('detail', '')))
" <<< "$CODE_ONLY" 2>/dev/null) && _ran_policy_findings=true
fi

if ! $_ran_policy_findings; then
    echo "$CODE_ONLY" | grep -qE '\brm\s+-(rf|fr)\s+/' && \
        finding 30 critical "rm -rf on root path" "Deletes files recursively — verify the exact path"
    echo "$CODE_ONLY" | grep -qE '\bsudo\s' && \
        finding 30 critical "uses sudo" "Elevated privileges — is this genuinely necessary?"
    echo "$CODE_ONLY" | grep -qE 'curl.*\|\s*(ba)?sh|wget.*\|\s*(ba)?sh' && \
        finding 30 critical "pipes URL to shell" "Remote code execution — verify the URL is trusted"
    echo "$CODE_ONLY" | grep -qE '\beval\s' && \
        finding 30 critical "uses eval" "Arbitrary code execution — verify the evaluated string"
    echo "$CODE_ONLY" | grep -qE 'git\s+push\s+--force' && \
        finding 20 high "git force push" "Overwrites remote history — cannot be undone"
    echo "$CODE_ONLY" | grep -qE 'git\s+reset\s+--hard' && \
        finding 20 high "git hard reset" "Discards uncommitted changes permanently"
    echo "$CODE_ONLY" | grep -qE 'chmod\s+777' && \
        finding 20 high "chmod 777" "World-writable — security risk"
    echo "$CODE_ONLY" | grep -qE '>\s*~/\.(ssh|gnupg|claude/settings)' && \
        finding 20 high "writes to sensitive dotfile" "Modifies security-critical config"
    echo "$CODE_ONLY" | grep -qE '>\s*~/\.zshrc|>\s*~/\.zprofile' && \
        finding 15 high "modifies shell config" "Changes apply to all future shell sessions"
    echo "$CODE_ONLY" | grep -qiE 'password|secret|token|api.key' && \
        finding 10 medium "handles credentials" "Verify secrets stored securely (0600 perms)"
    echo "$CODE_ONLY" | grep -qE 'brew\s+install|pip3?\s+install|npm\s+install\s+-g' && \
        finding 10 medium "installs packages" "New dependency — native alternative?"
    echo "$CODE_ONLY" | grep -qE 'launchctl\s+load|launchctl\s+unload' && \
        finding 5 medium "modifies launchd" "Service change persists across reboots"
    echo "$CODE_ONLY" | grep -qE '\bchmod\s' && \
        finding 5 medium "changes permissions" "Verify target path and mode"
    echo "$CODE_ONLY" | grep -qE '\bcurl\s|\bwget\s' && \
        finding 5 low "network requests" "Verify target domain is trusted"
fi

[ $DANGER -gt 100 ] && DANGER=100

# Load threshold from policy or use default
HIGH_RISK_THRESHOLD=50
if [ -f "$POLICY_FILE" ]; then
    _threshold=$(python3 -c "
try:
    import yaml
    print(yaml.safe_load(open('$POLICY_FILE')).get('high_risk_threshold', 50))
except:
    print(50)
" 2>/dev/null)
    [ -n "$_threshold" ] && HIGH_RISK_THRESHOLD="$_threshold"
fi

# ─── RISK ASSESSMENT ───
echo ""
printf "${YELLOW}───── RISK ASSESSMENT ─────────────────────────────────────${RESET}\n"
echo ""

if [ $DANGER -eq 0 ]; then
    printf "  ${GREEN}${BOLD}Risk: %d/100 — safe${RESET}  ${DIM}(no findings)${RESET}\n" "$DANGER"
elif [ $DANGER -le 20 ]; then
    printf "  ${GREEN}Risk: %d/100 — low risk${RESET}\n" "$DANGER"
elif [ $DANGER -le $HIGH_RISK_THRESHOLD ]; then
    printf "  ${YELLOW}Risk: %d/100 — review findings below${RESET}\n" "$DANGER"
else
    printf "  ${RED}${BOLD}Risk: %d/100 — HIGH RISK — read every line of CODE above${RESET}\n" "$DANGER"
fi

if [ -n "$FINDINGS" ]; then
    echo ""
    printf "$FINDINGS"
fi

# ─── CONFIRMATION ───
echo ""
printf "${GREEN}───── CONFIRMATION ────────────────────────────────────────${RESET}\n"
echo ""

if [ $DANGER -gt $HIGH_RISK_THRESHOLD ]; then
    printf "  ${RED}${BOLD}Type 'yes' to execute:${RESET} "
    read -r confirm
    [[ "$confirm" != "yes" ]] && { echo "  Cancelled."; exit 1; }
else
    printf "  Execute? [y/N] "
    read -r confirm
    [[ "$confirm" != [yY] ]] && { echo "  Cancelled."; exit 1; }
fi

# ─── RUNNING... ───
echo ""
printf "${MAGENTA}───── RUNNING... ──────────────────────────────────────────${RESET}\n"
echo ""

LOGFILE="$RAX_STATE_DIR/last-action-log.txt"
( source "$ACTION" ) 2>&1 | tee "$LOGFILE"
status=${PIPESTATUS[0]}

rm -f "$ACTION"

# ─── VERIFY ───
verify_status=""
echo ""
printf "${BLUE}───── VERIFY ──────────────────────────────────────────────${RESET}\n"
if [ $status -ne 0 ]; then
    printf "  ${RED}${BOLD}${CROSS} FAILED${RESET} (exit %d)  ${DIM}— action did not complete${RESET}\n" "$status"
    if [ -n "$ROLLBACK_CMD" ]; then
        printf "  ${YELLOW}To undo: %s${RESET}\n" "$ROLLBACK_CMD"
    fi
elif [ -n "$VERIFY_CMD" ]; then
    printf "  ${DIM}Checking the action produced the expected result...${RESET}\n"
    printf "  ${DIM}Running: %s${RESET}\n" "$VERIFY_CMD"
    echo ""
    if eval "$VERIFY_CMD" >> "$LOGFILE" 2>&1; then
        verify_status=0
        printf "  ${GREEN}${BOLD}${CHECK} COMPLETED${RESET}  ${DIM}— action ran and verification passed${RESET}\n"
    else
        verify_status=$?
        printf "  ${RED}${BOLD}${CROSS} VERIFY FAILED${RESET}  ${DIM}— action ran but verification exited %d${RESET}\n" "$verify_status"
        if [ -n "$ROLLBACK_CMD" ]; then
            printf "  ${YELLOW}To undo: %s${RESET}\n" "$ROLLBACK_CMD"
        fi
    fi
else
    printf "  ${GREEN}${BOLD}${CHECK} COMPLETED${RESET}  ${DIM}— action ran (no verify command provided)${RESET}\n"
fi

# --- Classify action ---
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
if [ -z "${RAX_CATEGORY:-}" ]; then
    RAX_CATEGORY="$(PYTHONPATH="$REPO_DIR" python3 -c "
try:
    from lib.hitl_router import classify_action
    from pathlib import Path
    print(classify_action(Path('$ACTION')))
except Exception:
    print('rax')
" 2>/dev/null || echo "rax")"
fi
export RAX_CATEGORY="${RAX_CATEGORY:-rax}"

# --- Write result + audit trail ---
export OUTPUT_TAIL="$(tail -30 "$LOGFILE" 2>/dev/null || echo "(no output)")"
export RAX_REPO="${REPO_HEADER:-$DETECTED_REPO}"
export RAX_WORKDIR="${WORKDIR_HEADER:-$ORIGINAL_DIR}"

python3 - "$RESULT_FILE" "$status" "$PURPOSE" "${verify_status:-}" "${ROLLBACK_CMD:-}" "$ACTION_ID" "$DANGER" "$SESSION_ID" "$AUDIT_FILE" "$RAX_CATEGORY" <<'PYEOF'
import json, sys, time, os

category = sys.argv[10] if len(sys.argv) > 10 else os.environ.get("RAX_CATEGORY", "rax")
entry = {
    "ts": int(time.time()),
    "action_id": sys.argv[6],
    "exit": int(sys.argv[2]),
    "purpose": sys.argv[3],
    "danger_score": int(sys.argv[7]),
    "session_id": sys.argv[8],
    "category": category,
    "classified_by": "router" if category != "rax" else "default",
    "review_needed": category == "rax",
    "output_tail": os.environ.get("OUTPUT_TAIL", "")[:2000],
}
repo = os.environ.get("RAX_REPO", "")
if repo:
    entry["repo"] = repo
workdir = os.environ.get("RAX_WORKDIR", "")
if workdir:
    entry["workdir"] = workdir
verify = sys.argv[4]
if verify:
    try:
        entry["verify_exit"] = int(verify)
    except ValueError:
        pass
rollback = sys.argv[5]
if rollback:
    entry["rollback"] = rollback

result_path = sys.argv[1]
os.makedirs(os.path.dirname(result_path), exist_ok=True)
with open(result_path, "w") as f:
    json.dump(entry, f)

audit_path = sys.argv[9]
os.makedirs(os.path.dirname(audit_path), exist_ok=True)
audit_entry = {k: v for k, v in entry.items() if k != "output_tail"}
with open(audit_path, "a") as f:
    f.write(json.dumps(audit_entry) + "\n")
PYEOF

# ─── ISSUE LINK ───
if [ -n "$ISSUE" ] && [ "$status" -eq 0 ] && command -v gh >/dev/null 2>&1; then
    echo ""
    printf "${CYAN}───── ISSUE LINK ──────────────────────────────────────────${RESET}\n"
    echo ""
    # Try issue-verify if available (check common locations)
    ISSUE_VERIFY=""
    for iv_path in "$(dirname "$0")/issue-verify" "$HOME/.local/bin/issue-verify"; do
        if [ -f "$iv_path" ]; then
            ISSUE_VERIFY="$iv_path"
            break
        fi
    done

    if [ -n "$ISSUE_VERIFY" ]; then
        if python3 "$ISSUE_VERIFY" "$ISSUE" --comment >/dev/null 2>&1; then
            printf "  ${GREEN}${BOLD}${CHECK} #${ISSUE}:${RESET} all runnable criteria pass, comment posted\n"
        else
            iv_exit=$?
            if [ "$iv_exit" = "2" ]; then
                if gh issue comment "$ISSUE" \
                    --body "rsax \`$ACTION_ID\`: completed — $PURPOSE" >/dev/null 2>&1; then
                    printf "  ${GREEN}${CHECK} #${ISSUE}:${RESET} posted rsax confirmation ${DIM}(no formal criteria)${RESET}\n"
                fi
            else
                printf "  ${YELLOW}${WARN_ICON} #${ISSUE}:${RESET} issue-verify found failing criteria ${DIM}(exit $iv_exit)${RESET}\n"
            fi
        fi
    else
        if gh issue comment "$ISSUE" \
            --body "rsax \`$ACTION_ID\`: completed — $PURPOSE" >/dev/null 2>&1; then
            printf "  ${GREEN}${CHECK} #${ISSUE}:${RESET} posted rsax confirmation\n"
        fi
    fi
fi

# Machine-readable summary — agent parses this from `! rax` output directly.
if [ $status -eq 0 ]; then
    if [ "${verify_status:-}" = "0" ]; then
        echo "[RSAX:completed,verified] purpose=\"$PURPOSE\" exit=0 verify=0 id=$ACTION_ID"
    elif [ -n "${verify_status:-}" ]; then
        echo "[RSAX:completed,verify_failed] purpose=\"$PURPOSE\" exit=0 verify=$verify_status id=$ACTION_ID"
    else
        echo "[RSAX:completed] purpose=\"$PURPOSE\" exit=0 id=$ACTION_ID"
    fi
else
    echo "[RSAX:failed] purpose=\"$PURPOSE\" exit=$status id=$ACTION_ID"
fi

# ─── FAILURE NOTIFICATION ───
if [ $status -ne 0 ] || [ "${verify_status:-0}" -ne 0 ]; then
    _rax_fail_reason=""
    [ $status -ne 0 ] && _rax_fail_reason="action failed (exit $status)"
    [ "${verify_status:-0}" -ne 0 ] && _rax_fail_reason="verification failed (exit ${verify_status:-0})"
    _rax_fail_repo="${REPO_HEADER:-eqdmc/security}"
    if command -v gh >/dev/null 2>&1; then
        gh issue create -R "$_rax_fail_repo" \
            --title "[rax-failure] $ACTION_ID — $_rax_fail_reason" \
            --label "agent-work,rax-failure" \
            --body "## rax action failed\n\n**Action:** \`$ACTION_ID\`\n**Purpose:** ${PURPOSE:-unknown}\n**Reason:** $_rax_fail_reason\n\nSee audit log for details: $AUDIT_FILE\n\n*Auto-reported by rax*" \
            2>/dev/null | sed 's/^/  /' || true
        printf "  ${YELLOW}⚠  rax action failed — issue created for triage${RESET}\n"
    fi
    unset _rax_fail_reason _rax_fail_repo
fi

# ─── FEEDBACK (via shared library) ───
_rax_fb_lib="$(realpath "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../lib/rax-feedback.sh" 2>/dev/null || echo "")"
if [ -n "$_rax_fb_lib" ] && [ -f "$_rax_fb_lib" ]; then
  source "$_rax_fb_lib"
  collect_feedback "$ACTION_ID" "${PURPOSE:-unknown}"
fi
unset _rax_fb_lib

# ─── NEXT STEPS ───
echo ""
printf "${WHITE}───── NEXT STEPS ──────────────────────────────────────────${RESET}\n"
echo ""
printf "  ${DIM}The agent can see this output directly. No copy-paste needed.${RESET}\n"
printf "  ${DIM}Just continue your conversation.${RESET}\n"
echo ""
printf "  ${DIM}Audit:     %s${RESET}\n" "$AUDIT_FILE"
printf "  ${DIM}Action ID: %s${RESET}\n" "$ACTION_ID"

exit $status
