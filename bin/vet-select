#!/usr/bin/env python3
"""vet-select — Multi-criteria package selection with scoring 1-100.
All weights and thresholds from packages/vetting-policy.json — zero hardcoded vars.

Usage:
  vet-select <purpose> --eco dnf --candidates "pkg1 pkg2 pkg3"
  vet-select --list-criteria
  vet-select --info <package>
"""

import json
import os
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).parent.parent
POLICY = json.loads((REPO / "packages" / "vetting-policy.json").read_text())


def load_scoring():
    """Load scoring config from policy SSOT."""
    return POLICY.get("scoring", {})


def score_license(license_str):
    """Score license using categories from policy."""
    config = load_scoring()
    categories = config.get("license_categories", {})
    l = license_str.lower()

    for category, cat_config in categories.items():
        if any(kw in l for kw in cat_config.get("keywords", [])):
            return cat_config.get("score", 0)
    return 0


def score_stars(stars):
    """Score GitHub stars using thresholds from policy."""
    config = load_scoring()
    thresholds = config.get("star_thresholds", [])
    for t in sorted(thresholds, key=lambda x: -x.get("min", 0)):
        if stars >= t.get("min", 0):
            return t.get("score", 0)
    return 0


def score_maintenance(days_since_push):
    """Score maintenance recency using thresholds from policy."""
    config = load_scoring()
    days_config = config.get("maintenance_days", [])
    for m in sorted(days_config, key=lambda x: x.get("max_days", 99999) if x.get("max_days") else 99999):
        max_d = m.get("max_days")
        if max_d is None or days_since_push <= max_d:
            return m.get("score", 0)
    return 0


def get_criteria():
    """Get criteria definitions from policy."""
    config = load_scoring()
    return config.get("criteria", [
        {"id": "license_fit", "weight": 20, "max": 20, "description": "License"},
        {"id": "maintenance", "weight": 20, "max": 20, "description": "Maintenance"},
        {"id": "community", "weight": 15, "max": 15, "description": "Community"},
    ])


def score_github_stats(repo_slug):
    """Score GitHub repo using config-driven thresholds."""
    if not repo_slug:
        return 0, {"note": "No GitHub repo", "stars": 0}

    try:
        data = subprocess.run(
            ["gh", "api", f"repos/{repo_slug}"],
            capture_output=True, text=True, timeout=10
        )
        if data.returncode != 0:
            return 0, {"note": "API error"}

        repo = json.loads(data.stdout)
        stars = repo.get("stargazers_count", 0)
        pushed_at = repo.get("pushed_at", "")

        star_score = score_stars(stars)

        maint_score = 5
        if pushed_at:
            pushed = datetime.fromisoformat(pushed_at.replace("Z", "+00:00"))
            days_since = (datetime.now(timezone.utc) - pushed).days
            maint_score = score_maintenance(days_since)

        return star_score + maint_score, {
            "stars": stars,
            "last_push": pushed_at[:10] if pushed_at else "unknown",
            "maintenance_score": maint_score,
        }
    except Exception as e:
        return 0, {"note": str(e)}


def evaluate_candidate(name, ecosystem, use_case):
    """Score a single candidate package using only SSOT-driven logic."""
    vet_result = _vet_package(name, ecosystem)
    verdict = vet_result.get("summary", {}).get("verdict", "UNKNOWN")
    meta = vet_result.get("metadata", {})
    license_str = meta.get("license", "unknown")
    gh_slug = meta.get("gh_slug", "")
    summary = vet_result.get("summary", "") or meta.get("summary", "")

    # Fallback to direct adapter if vet failed
    if license_str in ("unknown", "") or verdict == "UNKNOWN":
        adapter = REPO / "checks" / "adapters" / f"{ecosystem}.sh"
        if adapter.exists():
            result = subprocess.run(
                [str(adapter), name], capture_output=True, text=True, timeout=15
            )
            if result.returncode == 0 and result.stdout.strip():
                try:
                    direct = json.loads(result.stdout)
                    meta = direct.get("metadata", meta)
                    license_str = meta.get("license", license_str or "unknown")
                    gh_slug = meta.get("gh_slug", gh_slug or "")
                    summary = direct.get("summary", summary or "")
                except json.JSONDecodeError:
                    pass

    lic_score = score_license(license_str)
    gh_score, gh_details = score_github_stats(gh_slug)

    config = load_scoring()
    criteria = config.get("criteria", [])

    # Build scores dynamically from criteria config
    scores = {}
    for c in criteria:
        cid = c["id"]
        if cid == "license_fit":
            scores[cid] = lic_score
        elif cid == "maintenance":
            scores[cid] = gh_details.get("maintenance_score", gh_score // 3 + 5)
        elif cid == "community":
            scores[cid] = gh_details.get("stars", 0) // 1000 + 1
            if scores[cid] > c["max"]: scores[cid] = c["max"]
        elif cid == "security":
            scores[cid] = 15 if verdict != "BLOCKED" else 5
        elif cid == "features_fit":
            desc = summary if isinstance(summary, str) else str(summary)
            scores[cid] = 15 if use_case and any(w in desc.lower() for w in use_case.lower().split()) else 10
        else:
            scores[cid] = c["max"] // 2  # default to midpoint

    total = sum(scores.values())

    return {
        "name": name,
        "verdict": verdict,
        "total": total,
        "scores": scores,
        "details": {
            "license": license_str,
            "github": gh_slug or "N/A",
            "stars": gh_details.get("stars", 0),
        }
    }


def _vet_package(name, ecosystem):
    """Run vet on a package and return structured results."""
    try:
        subprocess.run(
            [str(REPO / "bin" / "vet"), name, "--eco", ecosystem, "--no-install"],
            capture_output=True, text=True, timeout=60
        )
        for f in Path("/tmp").glob("eqdmc-vet-*/result.json"):
            return json.loads(f.read_text())
    except:
        pass
    return {"summary": {"verdict": "UNKNOWN"}, "metadata": {}}


def main():
    if len(sys.argv) < 2 or "--help" in sys.argv:
        print(__doc__)
        sys.exit(1)

    if "--list-criteria" in sys.argv:
        criteria = get_criteria()
        for c in criteria:
            print(f"  {c['id']:20s} {c['weight']:2d} pts — {c['description']}")
        sys.exit(0)

    if "--info" in sys.argv:
        idx = sys.argv.index("--info") + 1
        name = sys.argv[idx] if idx < len(sys.argv) else ""
        if name:
            eco = "dnf"
            for i, a in enumerate(sys.argv):
                if a == "--eco" and i + 1 < len(sys.argv):
                    eco = sys.argv[i + 1]
            result = evaluate_candidate(name, eco, "backup")
            print(json.dumps(result, indent=2))
        sys.exit(0)

    purpose = sys.argv[1]
    candidates = []
    eco = "dnf"

    for i, arg in enumerate(sys.argv[2:]):
        if arg == "--eco" and i + 2 < len(sys.argv):
            eco = sys.argv[i + 3]
        elif arg == "--candidates" and i + 2 < len(sys.argv):
            candidates = sys.argv[i + 3].split()

    if not candidates:
        print(f"Usage: vet-select <purpose> --candidates \"pkg1 pkg2 pkg3\"")
        sys.exit(1)

    print(f"\nEvaluating candidates for: {purpose}\n")

    results = []
    for name in candidates:
        result = evaluate_candidate(name, eco, purpose)
        results.append(result)
        icon = "✅" if result["verdict"] == "APPROVED" else "❌"
        print(f"  {icon} {result['name']:20s}  {result['total']:3d}/100  {result['details']['license'][:35]}")

    results.sort(key=lambda r: -r["total"])
    best = results[0]

    print(f"\n  Recommended: {best['name']} ({best['total']}/100)\n")

    # Stage rax action — present choices for human decision
    rax_pending = os.environ.get("RAX_PENDING_FILE", str(Path.home() / ".rax" / "pending" / "1.sh"))
    os.makedirs(os.path.dirname(rax_pending), exist_ok=True)
    with open(rax_pending, "w") as f:
        f.write(f"""#!/bin/bash
# Purpose: Select package for {purpose}
# Priority: P1
# Type: select
# Description: Scored evaluation. Choose which package to proceed with.
# Issue: 98
# Action-ID: rax-select-{purpose}-$(date +%s)
# Repo: eqdmc/security
set -euo pipefail

echo ""
echo "Package selection: {purpose}"
echo "All scores from packages/vetting-policy.json"
echo ""
""")
        # Write each candidate
        for r in sorted(results, key=lambda x: -x["total"]):
            scores_str = " ".join(f"{k}={v}" for k, v in sorted(r["scores"].items()))
            f.write(f'echo "  {r["name"]:20s}  {r["total"]:3d}/100  [{r["verdict"]}]  {scores_str}"\n')

        f.write(f"""
echo ""
echo "Choose which package to add to the approved manifest:"
echo ""
read -p "Package name: " -r CHOICE
echo ""
case "$CHOICE" in
""")
        for r in results:
            f.write(f'  {r["name"]}) echo "Selected {r["name"]} ({r["total"]}/100)";;\n')
        f.write(f"""  *) echo "Not in list."; exit 1 ;;
esac
""")
    os.chmod(rax_pending, 0o600)
    print(f"  Rax action staged — run: rax")
    print(f"  Presents all candidates, you choose which to approve.")


if __name__ == "__main__":
    main()
