#!/usr/bin/env bash
# Render an ADR from vet-package JSON output (v2: multi-signal CVE quadrant)
# Usage: render-adr <vet-result.json> [sequence-number]
set -euo pipefail

INPUT="${1:?Usage: render-adr <vet-result.json> [seq]}"
SEQ="${2:-0000}"

pkg=$(jq -r '.package' "$INPUT")
ver=$(jq -r '.version' "$INPUT")
license=$(jq -r '.metadata.license' "$INPUT")
repo_url=$(jq -r '.metadata.repo_url' "$INPUT")
gh_slug=$(jq -r '.metadata.gh_slug' "$INPUT")
pub_time=$(jq -r '.metadata.publish_time' "$INPUT")
age_days=$(jq -r '.metadata.age_days' "$INPUT")
maint_count=$(jq -r '.metadata.maintainer_count' "$INPUT")
maintainers=$(jq -r '.metadata.maintainers | join(", ")' "$INPUT")
scorecard=$(jq -r '.metadata.scorecard' "$INPUT")
dep_count=$(jq -r '.metadata.dep_count' "$INPUT")
verdict=$(jq -r '.summary.verdict' "$INPUT")
gates_pass=$(jq -r '.summary.gates_pass' "$INPUT")
gates_total=$(jq -r '.summary.gates_total' "$INPUT")
scored_pass=$(jq -r '.summary.scored_pass' "$INPUT")
scored_total=$(jq -r '.summary.scored_total' "$INPUT")

vuln_total=$(jq -r '.vulns.total' "$INPUT")
p1_plus=$(jq -r '.vulns.quadrant."P1+_kev"' "$INPUT")
p1=$(jq -r '.vulns.quadrant.P1_high_likely' "$INPUT")
p2=$(jq -r '.vulns.quadrant.P2_high_unlikely' "$INPUT")
p3=$(jq -r '.vulns.quadrant.P3_low_likely' "$INPUT")
p4=$(jq -r '.vulns.quadrant.P4_low_unlikely' "$INPUT")
blocking=$(jq -r '.vulns.blocking' "$INPUT")

g_license=$(jq -r '.gates.license' "$INPUT")
g_cve=$(jq -r '.gates.cve' "$INPUT")
g_scripts=$(jq -r '.gates.install_scripts' "$INPUT")
g_quarantine=$(jq -r '.gates.quarantine_7d' "$INPUT")
g_match=$(jq -r '.gates.registry_repo_match' "$INPUT")
s_scorecard=$(jq -r '.scored.scorecard_gte_5' "$INPUT")
s_maintainers=$(jq -r '.scored.multiple_maintainers' "$INPUT")
s_postxz=$(jq -r '.scored.post_xz_clean' "$INPUT")
s_distro=$(jq -r '.scored.distro_inclusion' "$INPUT")
s_deps=$(jq -r '.scored.dep_depth_lte_500' "$INPUT")

today=$(date +%Y-%m-%d)

cat << EOF
# ADR-${SEQ}: \`npm/${pkg}\` — ${verdict}

- **Status:** Proposed
- **Date:** ${today}
- **Approved by:** pending (\`@eqdmc/security-review\`)
- **Verdict:** ${verdict} (gates: ${gates_pass}/${gates_total}, scored: ${scored_pass}/${scored_total})

## 1. Package

- **Name:** \`${pkg}\`
- **Ecosystem:** npm
- **Canonical source:** ${repo_url}
- **Version adopted:** \`${ver}\`
- **License:** ${license}

## 2. Binary vetting results

### Hard gates (all must PASS)

| # | Gate | Result | Evidence |
|---|---|---|---|
| 1 | License is permissive | ${g_license} | \`${license}\` |
| 2 | Zero P1+/P1 CVEs | ${g_cve} | ${vuln_total} total vulns, ${blocking} blocking (P1+: ${p1_plus}, P1: ${p1}) |
| 3 | No install scripts | ${g_scripts} | preinstall/postinstall/install checked |
| 4 | Quarantine >= 7 days | ${g_quarantine} | Published ${pub_time} (${age_days}d ago) |
| 5 | Registry-repo match | ${g_match} | npm -> ${gh_slug} |

### CVE quadrant breakdown (CVSS + EPSS + KEV)

| Priority | Count | Action | Description |
|---|---|---|---|
| P1+ (KEV) | ${p1_plus} | BLOCK | Confirmed exploited in the wild |
| P1 (high/likely) | ${p1} | BLOCK | CVSS >= 6.0 AND EPSS >= 0.2 |
| P2 (high/unlikely) | ${p2} | WARN | CVSS >= 6.0, EPSS < 0.2 |
| P3 (low/likely) | ${p3} | WARN | CVSS < 6.0, EPSS >= 0.2 |
| P4 (low/unlikely) | ${p4} | ACCEPT | CVSS < 6.0, EPSS < 0.2 |
EOF

if [[ "$vuln_total" -gt 0 ]]; then
  echo ""
  echo "### CVE details"
  echo ""
  echo "| CVE | Severity | CVSS (est) | EPSS | KEV | Priority |"
  echo "|---|---|---|---|---|---|"
  jq -r '.vulns.details[] | "| \(.cve) | \(.severity) | \(.cvss_est) | \(.epss) | \(.kev) | **\(.priority)** |"' "$INPUT"
fi

cat << EOF

### Scored checks (>= 3 must PASS)

| # | Check | Result | Evidence |
|---|---|---|---|
| 6 | OpenSSF Scorecard >= 5.0 | ${s_scorecard} | Score: ${scorecard} |
| 7 | Multiple maintainers | ${s_maintainers} | ${maint_count} maintainer(s): ${maintainers} |
| 8 | Post-xz heuristic clean | ${s_postxz} | < 2 flags triggered |
| 9 | Distro inclusion | ${s_distro} | npm registry |
| 10 | Dep depth <= 500 | ${s_deps} | ${dep_count} transitive deps |

## 3. Post-xz heuristic scan

- [$([ "$maint_count" -le 1 ] && echo "x" || echo " ")] Solo primary maintainer
- [ ] Binary test fixtures with no human-readable origin
- [ ] Build system doing work beyond compilation
- [ ] Social pressure to merge quickly
- [ ] Suspicious activity spike on previously-dormant package
- [ ] Typosquat-adjacent name
- [ ] Mismatched signing identity

## 4. References

- Upstream: ${repo_url}
- npm: https://www.npmjs.com/package/${pkg}/v/${ver}
- OSV: https://osv.dev/list?ecosystem=npm&q=${pkg}
$([ "$gh_slug" != "" ] && echo "- Scorecard: https://scorecard.dev/viewer/?uri=github.com/${gh_slug}")
$([ "$gh_slug" != "" ] && echo "- deps.dev: https://deps.dev/npm/${pkg}/${ver}")

## 5. Change log

| Date | Change | By |
|---|---|---|
| ${today} | Initial ADR (automated via vet-package v2) | @eqdmc/security-review |
EOF
