#!/usr/bin/env bash
# review-request — Request human review for a PR via rax.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PR="${1:-}"; REPO="${REPO:-eqdmc/security}"; SUMMARY=""
while [ $# -gt 0 ]; do
  case "$1" in --repo) REPO="$2"; shift 2 ;; --summary) SUMMARY="$2"; shift 2 ;; *) PR="$1"; shift ;;
  esac
done
[ -z "$PR" ] && { echo "Usage: review-request <pr-number> [--repo]"; exit 1; }

TITLE=$(gh pr view "$PR" -R "$REPO" --json title --jq '.title' 2>/dev/null)
AUTHOR=$(gh pr view "$PR" -R "$REPO" --json author --jq '.author.login' 2>/dev/null)
ADD=$(gh pr view "$PR" -R "$REPO" --json additions --jq '.additions' 2>/dev/null)
DEL=$(gh pr view "$PR" -R "$REPO" --json deletions --jq '.deletions' 2>/dev/null)

IS_SELF=false; [ "$AUTHOR" = "app/eqdmc-agent-bots" ] && IS_SELF=true

RAX_PENDING="${RAX_PENDING_FILE:-$HOME/.rax/pending.sh}"
mkdir -p "$(dirname "$RAX_PENDING")"
ACTION_ID="rax-review-$PR-$(date +%s)"

# Write rax action — all sections via printf/echo appends, no heredocs
rm -f "$RAX_PENDING"

# Header
printf '%s\n' "#!/bin/bash" > "$RAX_PENDING"
printf '%s\n' "# Purpose: Review PR #$PR ($REPO)" >> "$RAX_PENDING"
printf '%s\n' "# Description: $SUMMARY" >> "$RAX_PENDING"
printf '%s\n' "# Issue: $PR" >> "$RAX_PENDING"
printf '%s\n' "# Action-ID: $ACTION_ID" >> "$RAX_PENDING"
printf '%s\n' "# Repo: $REPO" >> "$RAX_PENDING"
printf '%s\n' 'set -euo pipefail' >> "$RAX_PENDING"
# Locate the repo bin directory for helper scripts
cat >> "$RAX_PENDING" << LOCATE
SCRIPT_DIR="\$(cd "\$(dirname "\$(realpath "\${BASH_SOURCE[0]}")")" && echo "\$(dirname "\$(dirname "\$0")")")"
# Fall back to common locations if BASH_SOURCE not available
[ -z "\${SCRIPT_DIR:-}" ] && SCRIPT_DIR="\$HOME/dev/eqdmc/security"
LOCATE
printf '%s\n' '' >> "$RAX_PENDING"

# Title section
printf '%s\n' 'printf "\n\033[1;35m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m\n"' >> "$RAX_PENDING"
printf '%s\n' 'printf "\033[1;35m  REVIEW REQUEST\033[0m\n"' >> "$RAX_PENDING"
printf '%s\n' 'printf "\033[1;35m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m\n"' >> "$RAX_PENDING"
printf '%s\n' 'echo ""' >> "$RAX_PENDING"

# PR info
printf '%s\n' "echo \"  Title:    $TITLE\"" >> "$RAX_PENDING"
printf '%s\n' "echo \"  Author:   $AUTHOR\"" >> "$RAX_PENDING"
printf '%s\n' "echo \"  Changes:  +$ADD/-$DEL\"" >> "$RAX_PENDING"
printf '%s\n' 'echo ""' >> "$RAX_PENDING"

# Binary checklist
printf '%s\n' 'printf "\033[1;36m───── BINARY CHECKLIST ────────────────────────────────\033[0m\n"' >> "$RAX_PENDING"
printf '%s\n' 'echo ""' >> "$RAX_PENDING"

# CI check
CI_OUT=$(gh pr view "$PR" -R "$REPO" --json statusCheckRollup --jq '([.statusCheckRollup[]? | select(.conclusion == "FAILURE")] | length == 0)' 2>/dev/null || echo "?")
if [ "$CI_OUT" = "true" ]; then
  printf '%s\n' 'printf "\033[0;32m✔\033[0m  CI passing\n"' >> "$RAX_PENDING"
else
  printf '%s\n' 'printf "\033[0;31m✘\033[0m  CI passing (unable to check)\n"' >> "$RAX_PENDING"
fi

# Mergeable check
MERGE_OUT=$(gh pr view "$PR" -R "$REPO" --json mergeable --jq '.mergeable' 2>/dev/null || echo "?")
if [ "$MERGE_OUT" = "MERGEABLE" ]; then
  printf '%s\n' 'printf "\033[0;32m✔\033[0m  No conflicts\n"' >> "$RAX_PENDING"
else
  printf '%s\n' 'printf "\033[0;31m✘\033[0m  No conflicts\n"' >> "$RAX_PENDING"
fi

printf '%s\n' 'echo ""' >> "$RAX_PENDING"
printf '%s\n' 'printf "\033[1;33m───── ACTIONS ─────────────────────────────────────────\033[0m\n"' >> "$RAX_PENDING"
printf '%s\n' 'echo ""' >> "$RAX_PENDING"
printf '%s\n' "echo \"  View PR:  gh pr view $PR -R $REPO\"" >> "$RAX_PENDING"
printf '%s\n' 'echo ""' >> "$RAX_PENDING"

# Self-approve warning
if [ "$IS_SELF" = true ]; then
  printf '%s\n' 'printf "\033[1;33m⚠  This PR was created by eqdmc-agent-bots.\033[0m\n"' >> "$RAX_PENDING"
  printf '%s\n' 'printf "\033[1;33m   Switching to eqdmc-merge-bot for approval...\033[0m\n"' >> "$RAX_PENDING"
  printf '%s\n' 'echo ""' >> "$RAX_PENDING"
fi

# Approve/reject prompt
printf '%s\n' 'read -p "  Approve this PR? (y/n) " -r ANS' >> "$RAX_PENDING"
printf '%s\n' 'echo ""' >> "$RAX_PENDING"
printf '%s\n' 'if [ "$ANS" = "y" ]; then' >> "$RAX_PENDING"

if [ "$IS_SELF" = true ]; then
  # Switch to merge-bot for approval (separate app = no self-approval conflict)
  printf '%s\n' "  MERGE_BOT_KEY=\$HOME/.ssh/eqdmc-merge-bot.pem" >> "$RAX_PENDING"
  printf '%s\n' '  if [ -f "$MERGE_BOT_KEY" ]; then' >> "$RAX_PENDING"
  printf '%s\n' "    echo \"  Authenticating as eqdmc-merge-bot...\"" >> "$RAX_PENDING"
  printf '%s\n' "    $REPO_DIR/bin/gh-merge-bot-auth 2>&1 | sed 's/^/  /'" >> "$RAX_PENDING"
  printf '%s\n' "    gh pr review $PR -R $REPO --approve 2>&1 | sed 's/^/  /'" >> "$RAX_PENDING"
  printf '%s\n' "    gh pr merge $PR -R $REPO --auto --squash 2>&1 | sed 's/^/  /'" >> "$RAX_PENDING"
  printf '%s\n' '    printf "\n\033[0;32m✔\033[0m  PR approved by merge-bot and queued.\n"' >> "$RAX_PENDING"
  printf '%s\n' '  else' >> "$RAX_PENDING"
  printf '%s\n' "    echo \"  Merge-bot key not found. Install:\"" >> "$RAX_PENDING"
  printf '%s\n' "    echo \"    cp ~/Downloads/eqdmc-merge-bot*.pem \$MERGE_BOT_KEY\"" >> "$RAX_PENDING"
  printf '%s\n' "    echo \"    chmod 600 \$MERGE_BOT_KEY\"" >> "$RAX_PENDING"
  printf '%s\n' '  fi' >> "$RAX_PENDING"
else
  printf '%s\n' "  gh pr review $PR -R $REPO --approve 2>&1 | sed 's/^/  /'" >> "$RAX_PENDING"
  printf '%s\n' "  gh pr merge $PR -R $REPO --auto --squash 2>&1 | sed 's/^/  /'" >> "$RAX_PENDING"
  printf '%s\n' '  printf "\n\033[0;32m✔\033[0m  PR approved and queued.\n"' >> "$RAX_PENDING"
fi

printf '%s\n' 'else' >> "$RAX_PENDING"
printf '%s\n' '  printf "\033[0;31m✘\033[0m  PR not approved.\n"' >> "$RAX_PENDING"
printf '%s\n' 'fi' >> "$RAX_PENDING"

chmod 600 "$RAX_PENDING"
echo "✅ Review request staged: rax"