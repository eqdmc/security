#!/usr/bin/env bash
# vet-release-notes — Fetch and summarize upstream release notes for a package.
#
# Agents use this to check what's new in a package version before requesting
# an upgrade or evaluating whether a package has the features they need.
#
# Usage:
#   vet-release-notes <package>                   # latest version
#   vet-release-notes <package> <version>         # specific version
#   vet-release-notes <package> --eco flathub    # explicit ecosystem
#   vet-release-notes <package> --diff v1.0 v2.0  # compare two versions
#
# Output: structured markdown with version, date, highlights, changes
#
# Requires: jq, curl
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MANIFEST="$SCRIPT_DIR/packages/manifest.json"
POLICY="$SCRIPT_DIR/packages/vetting-policy.json"
DIFF_MODE=false
VER_A=""
VER_B=""

# ── Help ──
if [ $# -eq 0 ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  sed -n 's/^# //p; s/^#$//p' "$0"
  exit 0
fi

PKG="$1"
shift

while [ $# -gt 0 ]; do
  case "$1" in
    --eco|--ecosystem) ECO="$2"; shift 2 ;;
    --diff) DIFF_MODE=true; VER_A="$2"; VER_B="$3"; shift 3 ;;
    --json) FORMAT="json"; shift ;;
    *) VERSION="$1"; shift ;;
  esac
done

# Find package in manifest or use arg
if [ -z "${ECO:-}" ]; then
  ECO=$(jq -r --arg p "$PKG" '[.vetted[] | select(.id == $p or .name == $p) | .ecosystem][0] // "auto"' "$MANIFEST")
fi

if [ -z "${VERSION:-}" ]; then
  VERSION=$(jq -r --arg p "$PKG" '[.vetted[] | select(.id == $p or .name == $p) | .version][0] // "latest"' "$MANIFEST")
fi

echo "# Release Notes: $PKG"
echo ""
echo "- **Ecosystem:** $ECO"
echo "- **Version:** $VERSION"
echo "- **Fetched:** $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo ""

# Try to fetch release notes based on ecosystem
case "$ECO" in
  flathub)
    # Get the GitHub repo from Flathub appstream metadata
    gh_repo=$(curl -sf "https://flathub.org/api/v2/appstream/$PKG" 2>/dev/null | jq -r '.urls.homepage // ""' | sed 's|https://github.com/||') || true
    if [ -n "$gh_repo" ]; then
      if [ "$DIFF_MODE" = true ]; then
        echo "## Changes from v$VER_A to v$VER_B"
        echo ""
        releases=$(curl -sf "https://api.github.com/repos/$gh_repo/releases" 2>/dev/null) || true
        echo "$releases" | jq -r --arg a "$VER_A" --arg b "$VER_B" '
          [.[] | select(.tag_name | test("^v?(\($a)|\($b))"))] |
          sort_by(.published_at) |
          .[] | "### \(.tag_name) (\(.published_at[:10]))\n\n\(.body[:500])\n"
        ' 2>/dev/null || echo "Could not fetch release data for diff."
      else
        echo "## Latest Release"
        echo ""
        release=$(curl -sf "https://api.github.com/repos/$gh_repo/releases/latest" 2>/dev/null) || true
        if [ -n "$release" ]; then
          tag=$(echo "$release" | jq -r '.tag_name // "unknown"')
          date=$(echo "$release" | jq -r '.published_at[:10] // "unknown"')
          body=$(echo "$release" | jq -r '.body // "No release notes"')
          echo "**$tag** — released $date"
          echo ""
          echo "$body" | head -80
        else
          echo "No release notes found on GitHub."
        fi
      fi
    else
      echo "No GitHub repo found for $PKG on Flathub."
      echo "Check https://flathub.org/apps/$PKG for details."
    fi
    ;;

  npm)
    echo "## Package metadata"
    echo ""
    pkg_data=$(curl -sf "https://registry.npmjs.org/$PKG" 2>/dev/null) || true
    if [ -n "$pkg_data" ]; then
      desc=$(echo "$pkg_data" | jq -r '.description // "No description"')
      echo "$desc"
      echo ""
      echo "**Homepage:** $(echo "$pkg_data" | jq -r '.homepage // "N/A"')"
      echo "**Latest version:** $(echo "$pkg_data" | jq -r '.["dist-tags"].latest // "N/A"')"
      if [ "$DIFF_MODE" = true ]; then
        echo ""
        echo "## Version history"
        echo "$pkg_data" | jq -r --arg a "$VER_A" --arg b "$VER_B" '
          .time | to_entries | 
          [.[] | select(.key | test("^\($a)$|^\($b)$"))] |
          .[] | "- \(.key): \(.value[:10])"
        ' 2>/dev/null
      fi
    fi
    ;;

  *)
    echo "Release notes not yet available for ecosystem: $ECO"
    echo "Check the package's upstream website or repository directly."
    ;;
esac

echo ""
echo "---"
echo "*Generated by bin/vet-release-notes*"
