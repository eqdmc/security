#!/usr/bin/env python3
"""rax-feedback — Submit feedback on the rax HITL process.

Usage:
  rax-feedback --action <action-id> --rating good|slow|confusing|broken
  rax-feedback --action <action-id> --rating good --note "Worked great"
  rax-feedback --list           # show recent feedback
  rax-feedback --stats          # aggregate metrics

Ratings:
  good       — Worked as expected, smooth process
  slow       — Too many steps, took too long
  confusing  — Unclear what to do or what happened
  broken     — Bug or error in the rax flow

Feedback creates a GitHub issue on eqdmc/security with labels:
  rax-feedback, rax-{type}, rating:{rating}
"""

import json
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent / "lib"))
from rax_config import default_repo

REPO = default_repo()
AUDIT_FILE = os.path.expanduser("~/.rax/state/audit.jsonl")
FEEDBACK_FILE = os.path.expanduser("~/.rax/state/feedback.jsonl")


def submit_feedback(action_id: str, rating: str, note: str = "",
                    satisfaction: str = "", achieved: str = "", improve: str = ""):
    """Submit feedback, creating a GitHub issue."""
    valid_ratings = ("good", "slow", "confusing", "broken", "neutral", "needs-work", "submitted")
    if rating not in valid_ratings:
        print(f"Invalid rating: {rating} (use: {', '.join(valid_ratings)})")
        sys.exit(1)

    # Find the action in the audit log to get its type
    action_type = "generic"
    action_purpose = action_id
    if os.path.exists(AUDIT_FILE):
        with open(AUDIT_FILE) as f:
            for line in f:
                try:
                    entry = json.loads(line)
                    if entry.get("action_id") == action_id:
                        action_type = entry.get("category", "generic")
                        action_purpose = entry.get("purpose", action_id)
                        break
                except json.JSONDecodeError:
                    pass

    # Write to local feedback log (structured format)
    os.makedirs(os.path.dirname(FEEDBACK_FILE), exist_ok=True)
    feedback = {
        "ts": int(datetime.now().timestamp()),
        "action_id": action_id,
        "satisfaction": satisfaction or "",
        "achieved_goal": achieved or "",
        "improvement": improve or "",
        "note": note[:500],
        "action_type": action_type,
        "purpose": action_purpose,
    }
    with open(FEEDBACK_FILE, "a") as f:
        f.write(json.dumps(feedback) + "\n")

    # Create GitHub issue with structured body
    sat_display = f"{satisfaction}/5" if satisfaction else "not rated"
    goal_display = "yes" if achieved and achieved.lower() in ("y", "yes") else "no" if achieved else "not answered"
    title = f"[rax-feedback] sat={satisfaction or '?'} goal={achieved or '?'}"
    body = (
        f"## rax feedback\n\n"
        f"**Action:** `{action_id}`\n"
        f"**Purpose:** {action_purpose}\n"
        f"**Satisfaction:** {sat_display}\n"
        f"**Achieved goal:** {goal_display}\n"
        f"**Improvement:** {improve or 'none'}\n\n"
        f"---\n*Submitted by rax v0.2.1*"
    )
    labels = "agent-work,rax-feedback"
    if rating and rating not in ("submitted",):
        labels += f",rating:{rating}"
    if action_type != "generic":
        labels += f",rax-{action_type}"

    result = subprocess.run(
        ["gh", "issue", "create", "-R", REPO,
         "--title", title,
         "--label", labels,
         "--body", body],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        print(f"Feedback submitted: {result.stdout.strip()}")
    else:
        print(f"Feedback logged locally (GitHub issue failed: {result.stderr})")

    print(f"  Action: {action_id}")
    print(f"  Satisfaction: {sat_display}")
    print(f"  Achieved goal: {goal_display}")
    if improve:
        print(f"  Improvement: {improve}")


def list_feedback():
    """Show recent feedback entries."""
    if not os.path.exists(FEEDBACK_FILE):
        print("No feedback yet.")
        return
    with open(FEEDBACK_FILE) as f:
        for line in f:
            try:
                fb = json.loads(line)
                ts = datetime.fromtimestamp(fb["ts"]).strftime("%Y-%m-%d")
                print(f"  {ts} [{fb['rating']:10s}] {fb['action_id'][:30]:30s} {fb.get('purpose', '')[:50]}")
            except json.JSONDecodeError:
                pass


def show_stats():
    """Show aggregate feedback metrics."""
    if not os.path.exists(FEEDBACK_FILE):
        print("No feedback data yet.")
        return

    satisfaction_total = 0
    satisfaction_count = 0
    goal_achieved = 0
    total = 0
    by_type = {}
    improvements = []

    with open(FEEDBACK_FILE) as f:
        for line in f:
            try:
                fb = json.loads(line)
                total += 1
                t = fb.get("action_type", "generic")
                by_type[t] = by_type.get(t, 0) + 1

                # Satisfaction score
                sat = fb.get("satisfaction", "")
                if sat and sat.isdigit():
                    s = int(sat)
                    if 1 <= s <= 5:
                        satisfaction_total += s
                        satisfaction_count += 1

                # Goal achieved
                goal = fb.get("achieved_goal", "")
                if goal and goal.lower() in ("y", "yes", "true"):
                    goal_achieved += 1

                # Improvement suggestions
                imp = fb.get("improvement", "")
                if imp and imp != "none":
                    improvements.append(imp)
            except json.JSONDecodeError:
                pass

    avg_sat = satisfaction_total / satisfaction_count if satisfaction_count else 0

    print(f"Total feedback entries: {total}")
    print(f"\nSatisfaction: {avg_sat:.1f}/5 ({satisfaction_count} ratings)")
    if total > 0:
        print(f"Goal achieved: {goal_achieved}/{total} ({goal_achieved * 100 // total}%)")
    print(f"\nBy action type:")
    for t, c in sorted(by_type.items(), key=lambda x: -x[1]):
        print(f"  {t:15s}: {c:3d}")
    if improvements:
        print(f"\nImprovement suggestions ({len(improvements)}):")
        for imp in improvements[:5]:
            print(f"  - {imp[:100]}")


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    if "--list" in sys.argv:
        list_feedback()
        sys.exit(0)

    if "--stats" in sys.argv:
        show_stats()
        sys.exit(0)

    action_id = None
    rating = None
    note = ""
    satisfaction = ""
    achieved = ""
    improve = ""

    for i, arg in enumerate(sys.argv[1:]):
        if arg == "--action" and i + 1 < len(sys.argv) - 1:
            action_id = sys.argv[i + 2]
        elif arg == "--rating" and i + 1 < len(sys.argv) - 1:
            rating = sys.argv[i + 2]
        elif arg == "--note" and i + 1 < len(sys.argv) - 1:
            note = sys.argv[i + 2]
        elif arg == "--satisfaction" and i + 1 < len(sys.argv) - 1:
            satisfaction = sys.argv[i + 2]
        elif arg == "--achieved" and i + 1 < len(sys.argv) - 1:
            achieved = sys.argv[i + 2]
        elif arg == "--improve" and i + 1 < len(sys.argv) - 1:
            improve = sys.argv[i + 2]

    if not action_id:
        print("Usage: rax-feedback --action <id> [--satisfaction 4] [--achieved y] [--improve ...]")
        sys.exit(1)

    submit_feedback(action_id, rating or "submitted", note, satisfaction, achieved, improve)


if __name__ == "__main__":
    main()
