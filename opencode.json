{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-v4-flash",
  "disabled_providers": [
    "openai",
    "google"
  ],
  "permission": {
    "bash": {
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "which *": "allow",
      "command -v *": "allow",
      "type *": "allow",
      "jq *": "allow",
      "date *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "python3 *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git fetch*": "allow",
      "git pull*": "allow",
      "git checkout *": "allow",
      "git branch *": "allow",
      "bin/vet*": "allow",
      "bin/vet-install*": "allow",
      "./bin/vet*": "allow",
      "./bin/vet-install*": "allow",
      "bash packages/install.sh*": "allow",
      "git push*": "ask",
      "git push *--force*": "ask",
      "gh repo edit*": "ask",
      "gh api*-X DELETE*": "ask",
      "gh api*-X PATCH*": "ask",
      "gh api*-X PUT*": "ask",
      "gh api*ruleset*": "ask",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "flatpak install*": "deny",
      "flatpak update*": "deny",
      "flatpak upgrade*": "deny",
      "dnf install*": "deny",
      "dnf update*": "deny",
      "dnf upgrade*": "deny",
      "apt install*": "deny",
      "apt-get install*": "deny",
      "brew install*": "deny",
      "brew cask install*": "deny",
      "brew uninstall*": "deny",
      "brew remove*": "deny",
      "brew upgrade*": "deny",
      "pip install*": "deny",
      "pip3 install*": "deny",
      "pip uninstall*": "deny",
      "pip3 uninstall*": "deny",
      "pipx install*": "deny",
      "uv add*": "deny",
      "uv pip install*": "deny",
      "npm install -g*": "deny",
      "npm uninstall -g*": "deny",
      "yarn global*": "deny",
      "pnpm add -g*": "deny",
      "cargo install*": "deny",
      "snap install*": "deny",
      "gem install*": "deny",
      "go install*": "deny",
      "curl * | sh*": "deny",
      "curl * | bash*": "deny",
      "wget * | sh*": "deny",
      "wget * | bash*": "deny",
      "cat * | sh*": "deny",
      "head * | sh*": "deny",
      "tail * | sh*": "deny",
      "bash *-c*curl*": "deny",
      "bash *-c*wget*": "deny",
      "eval *curl*": "deny",
      "eval *wget*": "deny",
      "source *(*curl*": "deny",
      "source *(*wget*": "deny",
      "base64 *|*sh*": "deny",
      "base64 *|*bash*": "deny",
      "curl *-o*&&*bash*": "deny",
      "curl *-o*&&*sh*": "deny",
      "wget *-O*&&*bash*": "deny",
      "python* -m pip install": "deny",
      "deno install": "deny",
      "bun install": "deny",
      "*": "ask"
    },
    "edit": "allow",
    "write": "allow",
    "webfetch": "allow"
  },
  "instructions": [
    "../eqdmc/agent-harness/AGENTS.md",
    "../eqdmc/agent-harness/ENVIRONMENT.md",
    "../eqdmc/agent-harness/HARNESS.md",
    "AGENTS.md",
    ".opencode/instructions/rax-check.md"
  ]
}
