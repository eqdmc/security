{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-v4-flash",
  "disabled_providers": ["openai", "google"],
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "which *": "allow",
      "command -v *": "allow",
      "type *": "allow",
      "jq *": "allow",
      "date *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git fetch*": "allow",
      "git pull*": "allow",
      "git push*": "ask",
      "git push *--force*": "ask",
      "git checkout *": "allow",
      "git branch *": "allow",
      "gh repo edit*": "ask",
      "gh api*-X DELETE*": "ask",
      "gh api*-X PATCH*": "ask",
      "gh api*-X PUT*": "ask",
      "gh api*ruleset*": "ask",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "flatpak install*": "ask",
      "flatpak update*": "ask",
      "flatpak upgrade*": "ask",
      "dnf install*": "ask",
      "dnf update*": "ask",
      "apt install*": "ask",
      "brew install*": "ask",
      "brew cask install*": "ask",
      "pip install*": "ask",
      "pip3 install*": "ask",
      "cargo install*": "ask",
      "snap install*": "ask"
    },
    "edit": "allow",
    "write": "allow",
    "webfetch": "allow"
  },
  "instructions": [
    "../eqdmc/agent-harness/AGENTS.md",
    "../eqdmc/agent-harness/ENVIRONMENT.md",
    "../eqdmc/agent-harness/HARNESS.md",
    "AGENTS.md"
  ]
}
