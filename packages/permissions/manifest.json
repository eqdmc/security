  "note": "GitHub Enterprise features, org-level policies, and app permissions. All GitHub API permissions documented with their scopes and current usage.",
  "token": {
    "id": "gh-eqdmc-admin",
    "type": "github-fine-grained-pat",
    "repositories": ["eqdmc/security"],
    "permissions": {
      "contents": "write",
      "pull_requests": "write",
      "metadata": "read",
      "issues": "read"
    },
    "missing_repos": ["eqdmc/dotfiles", "eqdmc/agent-harness", "eqdmc/infra"],
    "legacy_scopes_removed": ["admin:ssh_signing_key", "admin:public_key", "workflow", "gist"],
    "audit_note": "Created in hardening sprint. Scoped to security only. Cross-repo access will use GitHub App."
  },
  "github_apps": {
    "eqdmc-merge-bot": {
      "app_id": 4125320,
      "install_id": 142188577,
      "repository_selection": "all",
      "permissions": {
        "checks": "write",
        "contents": "write",
        "issues": "write",
        "metadata": "read",
        "pull_requests": "write"
      },
      "ruleset_bypass": {
        "main-protection": "always",
        "signed-commits": "none",
        "merge-queue": "always"
      },
      "note": "Auto-merge bot. Bypasses PR/CI requirements but NOT signing. Merge commits are GitHub-signed."
    },
    "eqdmc-agent-bot": {
      "status": "pending",
      "note": "To be created via rax action at ~/.rax/pending.sh. Will authenticate agents for cross-repo API access."
    }
  },
  "repository_rulesets": {
    "eqdmc/security": [
      {"name": "main-protection", "enforcement": "active", "source": "org",
       "rules": ["non_fast_forward", "deletion", "required_linear_history", "pull_request", "required_status_checks"],
       "bypass_actors": {"eqdmc-merge-bot": "always"}},
      {"name": "signed-commits", "enforcement": "active", "source": "repo",
       "rules": ["required_signatures"],
       "bypass_actors": {}},
      {"name": "merge-queue", "enforcement": "active", "source": "org",
       "rules": ["merge_queue"],
       "bypass_actors": {"org_admin": "always", "eqdmc-merge-bot": "always"}}
    ]
  },
  "org_features": {
